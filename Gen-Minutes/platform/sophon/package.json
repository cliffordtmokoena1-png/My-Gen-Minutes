{
  "name": "@GovClerkMinutes/sophon",
  "version": "0.1.0",
  "private": true,
  "description": "Dedicated NodeJS server for GovClerkMinutes.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "preinstall": "PUPPETEER_SKIP_DOWNLOAD=1",
    "build": "bun build ./src/entrypoints/index.ts ./src/entrypoints/rtmp-ingest.ts --target=node --format=esm --outdir=dist --packages=external",
    "deploy": "bash deploy/deploy.sh",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.932.0",
    "@aws-sdk/lib-storage": "^3.932.0",
    "@elevenlabs/elevenlabs-js": "^2.30.0",
    "@hono/node-server": "^1.11.0",
    "@hono/node-ws": "^1.2.0",
    "@planetscale/database": "^1.19.0",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.2.3",
    "file-type": "^21.1.0",
    "hono": "^4.4.0",
    "mime-db": "^1.54.0",
    "nodemon": "^3.1.11",
    "puppeteer": "^22.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0",
    "ws": "^8.18.3"
  }
}
